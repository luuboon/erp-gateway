# ─────────────────────────────────────────
#  ERP-SDA API Gateway — Variables de entorno (ejemplo)
#  Copia este archivo como .env y rellena los valores reales
# ─────────────────────────────────────────

PORT=3000
NODE_ENV=development

# JWT — mismo secret en todos los servicios
JWT_SECRET=your_jwt_secret_here_min_16_chars

# Secret compartido con los microservicios Go
GATEWAY_SECRET=your_gateway_secret_here

# URLs de los microservicios
USER_SERVICE_URL=http://localhost:3001
GROUP_SERVICE_URL=http://localhost:3002
TICKET_SERVICE_URL=http://localhost:3003

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS — origen del frontend Angular
CORS_ORIGINS=http://localhost:4200

# Base de datos de logs (Neon PostgreSQL)
LOG_DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx.neon.tech/erp_logs?sslmode=require
